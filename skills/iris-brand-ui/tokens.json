{
  "$schema": "https://iris.gogolook.com/tokens/v1",
  "$description": "IRIS design tokens — Intelligence Risk Integrated Solutions. Gogolook B2B.",

  "color": {
    "primary": {
      "value": "#41A9F6",
      "name": "Azure",
      "token": "--blue",
      "role": "Primary — actions, links, active states, key accents",
      "textRule": "White text/icons on Azure fills."
    },
    "secondary": {
      "value": "#0058EA",
      "name": "Gogolook Blue",
      "token": "--azure",
      "role": "Secondary — highlights, data-viz, icons",
      "textRule": "White text passes AA."
    },
    "accent": {
      "value": "#5A5B9F",
      "name": "Blue Iris",
      "token": "--iris",
      "role": "Accent — muted surfaces, supporting accents",
      "textRule": "White text passes AA (~6:1)."
    },
    "lightAccent": {
      "value": "#7EDFFE",
      "name": "Iris Sky",
      "token": "--sky",
      "role": "Light accent — tints, hover fills, chart-light, glows on dark",
      "textRule": "Fill only — use navy text, never as text color."
    },
    "navy": {
      "value": "#0F2647",
      "name": "Iris Navy",
      "token": "--navy",
      "role": "Ink, headings, sidebar, dark surfaces"
    },
    "mist": {
      "value": "#F3F8FE",
      "name": "Iris Mist",
      "token": "--mist",
      "role": "App background, cards (lightest surface)"
    },
    "white": {
      "value": "#FFFFFF",
      "name": "White",
      "token": "--white",
      "role": "Content surfaces"
    },
    "ink2": {
      "value": "#5A6577",
      "name": "Secondary Text",
      "token": "--ink-2",
      "role": "Body secondary text, captions, descriptions"
    },
    "line": {
      "value": "#E6ECF5",
      "name": "Border",
      "token": "--line",
      "role": "Borders, dividers, card outlines"
    },

    "semantic": {
      "success": {
        "value": "#2FB87A",
        "token": "--success",
        "role": "Low risk / positive / approved"
      },
      "riskHigh": {
        "value": "#E5484D",
        "token": "--risk-high",
        "role": "High risk / reject"
      },
      "riskMed": {
        "value": "#F5A623",
        "token": "--risk-med",
        "role": "Medium risk / caution / manual review"
      }
    },

    "riskScale": {
      "$description": "5-stop A-E risk level ramp. Data viz only — never decorative.",
      "A": { "value": "#2FB87A", "label": "Low risk" },
      "B": { "value": "#8FBE52", "label": "Below average risk" },
      "C": { "value": "#F5A623", "label": "Medium risk" },
      "D": { "value": "#EE6A45", "label": "Elevated risk" },
      "E": { "value": "#E5484D", "label": "High risk" }
    },

    "gradient": {
      "$description": "Brand gradient — hero and marketing surfaces only.",
      "stops": ["#0058EA", "#41A9F6", "#7EDFFE"],
      "names": ["Gogolook Blue", "Azure", "Iris Sky"],
      "css": "linear-gradient(100deg, #0058EA 0%, #41A9F6 52%, #7EDFFE 100%)"
    },

    "chart": {
      "$description": "Multi-series chart color order.",
      "series": [
        { "order": 1, "value": "#41A9F6", "name": "Azure" },
        { "order": 2, "value": "#0058EA", "name": "Gogolook Blue" },
        { "order": 3, "value": "#5A5B9F", "name": "Blue Iris" },
        { "order": 4, "value": "#7EDFFE", "name": "Iris Sky" },
        { "order": 5, "value": "rgba(15, 38, 71, 0.40)", "name": "Navy 40%" }
      ]
    }
  },

  "typography": {
    "families": {
      "display": {
        "value": "\"Plus Jakarta Sans\", system-ui, sans-serif",
        "token": "--display",
        "role": "Headlines, logotype, highlighted paragraphs",
        "weights": [300, 400, 500, 600],
        "googleFonts": "Plus+Jakarta+Sans:wght@300;400;500;600"
      },
      "body": {
        "value": "\"Inter\", system-ui, sans-serif",
        "token": "--body",
        "role": "Body copy, form controls, data tables",
        "weights": [400, 500, 600],
        "googleFonts": "Inter:wght@400;500;600"
      },
      "regional": {
        "value": "\"Noto Sans\", \"Noto Sans TC\", system-ui, sans-serif",
        "token": "--regional",
        "role": "CJK + multilingual body (TC/JP/KR/TH)",
        "weights": [400, 500, 700],
        "googleFonts": "Noto+Sans+TC:wght@400;500;700"
      }
    },

    "sizes": {
      "display-xl": { "value": "clamp(36px, 5.4vw, 64px)", "lineHeight": 1.08, "letterSpacing": "-0.01em", "family": "display", "weight": 500 },
      "display-lg": { "value": "clamp(32px, 4.6vw, 52px)", "lineHeight": 1.14, "letterSpacing": "-0.015em", "family": "display", "weight": 500 },
      "display-md": { "value": "clamp(28px, 4.2vw, 42px)", "lineHeight": 1.2, "letterSpacing": "-0.015em", "family": "display", "weight": 500 },
      "display-sm": { "value": "clamp(22px, 2.8vw, 34px)", "lineHeight": 1.3, "letterSpacing": "-0.01em", "family": "display", "weight": 500 },
      "heading-lg": { "value": "20px", "lineHeight": 1.3, "letterSpacing": "-0.01em", "family": "display", "weight": 500 },
      "heading-md": { "value": "17px", "lineHeight": 1.3, "letterSpacing": "-0.01em", "family": "display", "weight": 500 },
      "heading-sm": { "value": "15px", "lineHeight": 1.3, "letterSpacing": "-0.01em", "family": "display", "weight": 500 },
      "body-lg": { "value": "18px", "lineHeight": 1.7, "letterSpacing": "0", "family": "body", "weight": 400 },
      "body-md": { "value": "14px", "lineHeight": 1.65, "letterSpacing": "0", "family": "body", "weight": 400 },
      "body-sm": { "value": "13px", "lineHeight": 1.6, "letterSpacing": "0", "family": "body", "weight": 400 },
      "caption": { "value": "12px", "lineHeight": 1.5, "letterSpacing": "0.02em", "family": "body", "weight": 500 },
      "eyebrow": { "value": "12px", "lineHeight": 1, "letterSpacing": "0.26em", "family": "display", "weight": 600, "textTransform": "uppercase" },
      "ui-label": { "value": "11px", "lineHeight": 1, "letterSpacing": "0.08em", "family": "display", "weight": 600, "textTransform": "uppercase" },
      "score-xl": { "value": "52px", "lineHeight": 1, "letterSpacing": "-0.02em", "family": "display", "weight": 500, "fontVariantNumeric": "tabular-nums" },
      "score-lg": { "value": "36px", "lineHeight": 1, "letterSpacing": "-0.02em", "family": "display", "weight": 500, "fontVariantNumeric": "tabular-nums" },
      "score-md": { "value": "32px", "lineHeight": 1, "letterSpacing": "-0.02em", "family": "display", "weight": 500, "fontVariantNumeric": "tabular-nums" },
      "score-sm": { "value": "22px", "lineHeight": 1, "letterSpacing": "-0.02em", "family": "display", "weight": 500, "fontVariantNumeric": "tabular-nums" },
      "stat-hero": { "value": "clamp(32px, 3.8vw, 46px)", "lineHeight": 1, "letterSpacing": "-0.02em", "family": "display", "weight": 500, "fontVariantNumeric": "tabular-nums" }
    },

    "numericOverride": {
      "$description": "Apply tabular-nums to all scores, percentiles, currency, counts, and table figures.",
      "css": "font-variant-numeric: tabular-nums"
    }
  },

  "spacing": {
    "$description": "4px base scale.",
    "1":  { "value": "4px",  "token": "--sp-1" },
    "2":  { "value": "8px",  "token": "--sp-2" },
    "3":  { "value": "12px", "token": "--sp-3" },
    "4":  { "value": "16px", "token": "--sp-4" },
    "5":  { "value": "20px", "token": "--sp-5" },
    "6":  { "value": "24px", "token": "--sp-6" },
    "8":  { "value": "32px", "token": "--sp-8" },
    "10": { "value": "40px", "token": "--sp-10" },
    "12": { "value": "48px", "token": "--sp-12" },
    "16": { "value": "64px", "token": "--sp-16" },
    "20": { "value": "80px", "token": "--sp-20" },
    "24": { "value": "96px", "token": "--sp-24" }
  },

  "radius": {
    "sm":   { "value": "8px",  "token": "--r-sm",   "use": "Nav items, small toggles" },
    "md":   { "value": "10px", "token": "--r-md",   "use": "Buttons, inputs, toggles" },
    "lg":   { "value": "16px", "token": "--r-lg",   "use": "Tables, KPI cards, console panels" },
    "xl":   { "value": "18px", "token": "--r-xl",   "use": "Chart cards, section panels, brand cards" },
    "2xl":  { "value": "20px", "token": "--r-2xl",  "use": "Logo cards, hero cards" },
    "full": { "value": "999px","token": "--r-full", "use": "Badges, pills, toggles, percentile bars" }
  },

  "shadow": {
    "sm": {
      "value": "0 1px 3px rgba(15, 38, 71, 0.06)",
      "token": "--shadow-sm",
      "use": "Subtle lift — dropdowns, tooltips"
    },
    "md": {
      "value": "0 6px 20px rgba(15, 38, 71, 0.08)",
      "token": "--shadow-md",
      "use": "Cards, modals"
    },
    "lg": {
      "value": "0 10px 40px rgba(15, 38, 71, 0.10)",
      "token": "--shadow-lg",
      "use": "Console preview, elevated panels"
    },
    "xl": {
      "value": "0 20px 60px rgba(15, 38, 71, 0.14)",
      "token": "--shadow-xl",
      "use": "Hero overlays, full-screen modals"
    }
  },

  "breakpoint": {
    "sm":  { "value": "480px",  "label": "Small mobile" },
    "md":  { "value": "680px",  "label": "Large mobile / console sidebar collapse" },
    "lg":  { "value": "760px",  "label": "Tablet — 2-col grids" },
    "xl":  { "value": "860px",  "label": "Desktop — full layouts" },
    "max": { "value": "1080px", "label": "Max content width", "token": "--maxw" }
  },

  "transition": {
    "fast":    { "value": "0.15s ease", "use": "Button hover, focus ring, toggle" },
    "normal":  { "value": "0.2s ease",  "use": "Nav highlight, color transitions" },
    "slow":    { "value": "0.4s ease",  "use": "Gate fade, section reveals" },
    "chart":   { "value": "0.6s ease",  "use": "Bar fill animation, chart entry" }
  },

  "icon": {
    "viewBox": "0 0 24 24",
    "strokeWidth": 1.6,
    "strokeLinecap": "round",
    "strokeLinejoin": "round",
    "fill": "none",
    "defaultSize": "24px",
    "minSize": "16px",
    "displaySize": "32px",
    "defaultColor": "#0F2647"
  },

  "focus": {
    "$description": "Standard focus ring for all interactive elements.",
    "boxShadow": "0 0 0 3px rgba(65, 169, 246, 0.18)",
    "borderColor": "#41A9F6"
  }
}
